# Cloudflare R2 credentials for Learn Hub image uploads.
# Copy this file to `.env` and fill in the real values locally.

# Cloudflare account id, visible in the Cloudflare dashboard URL/sidebar.
CLOUDFLARE_ACCOUNT_ID=

# R2 API token credentials. Create an R2 token with read/write access to the target bucket.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Existing R2 bucket name.
R2_BUCKET=

# Public base URL used in Markdown image links.
# Prefer a custom domain, for example: https://img.example.com
# R2.dev public bucket URLs also work if you have enabled public access.
R2_PUBLIC_BASE_URL=

# Local image root. The upload script will strip this prefix when creating R2 object keys.
R2_LOCAL_IMAGE_ROOT=docs/public/images

# Optional prefix inside the bucket. Leave empty if object keys should start with `trading/...`.
# Example: learn-hub/images
R2_KEY_PREFIX=

# Optional HTTP cache policy attached to uploaded objects.
R2_CACHE_CONTROL=public, max-age=86400
